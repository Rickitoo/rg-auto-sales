Options -Indexes
<Files "teste_login.php">
    Require all denied
</Files>

RewriteEngine On
RewriteBase /RG_AUTO_SALES/

RewriteRule ^teste_login\.php$ - [F,L]
RewriteRule ^(\.git|app|storage|vendor|scripts|includes)(/|$) - [F,L]
RewriteRule \.(env|sql|bak|backup|zip|tar|gz|7z)$ - [F,L]

RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

RewriteRule ^$ public/index.php [L]
RewriteRule ^inicio/?$ public/index.php [L]
RewriteRule ^carros/?$ public/products.php [L]
RewriteRule ^carro/([0-9]+)/?$ public/product-details.php?id=$1 [L,QSA]
RewriteRule ^sobre/?$ public/about.php [L]
RewriteRule ^contacto/?$ public/contacto.php [L]
RewriteRule ^test-drive/?$ public/test_drive.php [L]
RewriteRule ^leasing/?$ public/leasing.php [L]
RewriteRule ^login/?$ public/account.php [L]
RewriteRule ^dashboard/?$ admin/dashboard.php [L]
RewriteRule ^crm/?$ admin/crm/inbox.php [L]
RewriteRule ^crm/inbox/?$ admin/crm/inbox.php [L]
RewriteRule ^admin/crm/?$ admin/crm/inbox.php [L]
RewriteRule ^admin/carros/?$ admin/carros/listar_carros.php [L]
RewriteRule ^admin/vendas/?$ admin/vendas/vendas.php [L]
RewriteRule ^admin/leads/?$ admin/leads/leads.php [L]
